void setup() {
  Serial.begin(9600);
  Wire.begin();

  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcdPrintLine(0, "Starting...");
  lcdPrintLine(1, "");

  Serial.println("Starting...");

  if (!mcp.begin_I2C(MCP_ADDR)) {
    Serial.println("MCP NOT FOUND");
    lcdPrintLine(0, "MCP NOT FOUND");
    while (1);
  }

  setupKeypad(albumRows, albumCols);
  setupKeypad(trackRows, trackCols);

  mp3Serial.begin(9600);

  if (!mp3.begin(mp3Serial)) {
    Serial.println("DFPlayer ERROR");
    lcdPrintLine(0, "DFPlayer ERROR");
    while (1);
  }

  mp3.volume(22);

  Serial.println("Ready!");
  showHome();
}

void loop() {
  int album = scanAlbumKeypad();

  if (album > 0) {
    selectedAlbum = album;
    typedTrack = "";

    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));

    Serial.print("Album ");
    Serial.print(selectedAlbum);
    Serial.print(": ");
    Serial.println(nameBuffer);

    lcd.clear();
    lcdPrintLine(0, nameBuffer);
    lcdPrintLine(1, "Enter track");
  }

  char key = scanTrackKeypad();

  if (key != 0) {
    handleTrackKey(key);
  }
}

void setupKeypad(byte rows[4], byte cols[3]) {
  for (int r = 0; r < 4; r++) {
    mcp.pinMode(rows[r], OUTPUT);
    mcp.digitalWrite(rows[r], HIGH);
  }

  for (int c = 0; c < 3; c++) {
    mcp.pinMode(cols[c], INPUT_PULLUP);
  }
}

int scanAlbumKeypad() {
  if (millis() - lastPress < debounceDelay) return 0;

  for (int r = 0; r < 4; r++) {
    setRowsHigh(albumRows);
    mcp.digitalWrite(albumRows[r], LOW);

    for (int c = 0; c < 3; c++) {
      if (mcp.digitalRead(albumCols[c]) == LOW) {
        lastPress = millis();
        return albumMap[r][c];
      }
    }
  }

  return 0;
}

char scanTrackKeypad() {
  if (millis() - lastPress < debounceDelay) return 0;

  for (int r = 0; r < 4; r++) {
    setRowsHigh(trackRows);
    mcp.digitalWrite(trackRows[r], LOW);

    for (int c = 0; c < 3; c++) {
      if (mcp.digitalRead(trackCols[c]) == LOW) {
        lastPress = millis();
        return trackMap[r][c];
      }
    }
  }

  return 0;
}

void setRowsHigh(byte rows[4]) {
  for (int r = 0; r < 4; r++) {
    mcp.digitalWrite(rows[r], HIGH);
  }
}

void handleTrackKey(char key) {
  if (key >= '0' && key <= '9') {
    if (typedTrack.length() < 3) {
      typedTrack += key;
    }

    Serial.print("Track typed: ");
    Serial.println(typedTrack);

    String line = "Track: " + typedTrack;
    lcdPrintLine(1, line.c_str());
  }

  if (key == '*') {
    typedTrack = "";
    Serial.println("Track cleared");
    lcdPrintLine(1, "Track cleared");
    delay(500);
    lcdPrintLine(1, "Enter track");
  }

  if (key == '#') {
    playSong();
  }
}

void playSong() {
  if (selectedAlbum == 0) {
    Serial.println("Pick an album first");
    lcdPrintLine(0, "Pick album first");
    lcdPrintLine(1, "");
    delay(1000);
    showHome();
    return;
  }

  if (typedTrack.length() == 0) {
    Serial.println("Type a track first");
    lcdPrintLine(1, "Type track first");
    delay(1000);
    return;
  }

  int track = typedTrack.toInt();

  if (track < 1 || track > trackCounts[selectedAlbum]) {
    Serial.print("Invalid track. Album has ");
    Serial.print(trackCounts[selectedAlbum]);
    Serial.println(" tracks.");

    lcdPrintLine(0, "Invalid track");
    char msg[17];
    snprintf(msg, sizeof(msg), "1-%d only", trackCounts[selectedAlbum]);
    lcdPrintLine(1, msg);

    typedTrack = "";
    delay(1500);

    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));
    lcdPrintLine(0, nameBuffer);
    lcdPrintLine(1, "Enter track");
    return;
  }

  char albumBuffer[40];
  char trackBuffer[80];

  getAlbumName(selectedAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(selectedAlbum, track, trackBuffer, sizeof(trackBuffer));

  Serial.print("Playing: ");
  Serial.print(albumBuffer);
  Serial.print(" / ");
  Serial.println(trackBuffer);

  lcd.clear();
  lcdPrintLine(0, albumBuffer);
  lcdPrintLine(1, trackBuffer);

  mp3.playFolder(selectedAlbum, track);

  typedTrack = "";
}

void getAlbumName(int album, char* buffer, size_t bufferSize) {
  if (album < 1 || album > 12) {
    strncpy(buffer, "Unknown Album", bufferSize);
    buffer[bufferSize - 1] = '\0';
    return;
  }

  PGM_P ptr = (PGM_P)pgm_read_word(&(albumNames[album]));
  strncpy_P(buffer, ptr, bufferSize);
  buffer[bufferSize - 1] = '\0';
}

void getTrackName(int album, int track, char* buffer, size_t bufferSize) {
  if (album < 1 || album > 12 || track < 1 || track > trackCounts[album]) {
    strncpy(buffer, "Unknown Track", bufferSize);
    buffer[bufferSize - 1] = '\0';
    return;
  }

  const char* const* albumPtr = (const char* const*)pgm_read_word(&(allTracks[album]));
  PGM_P trackPtr = (PGM_P)pgm_read_word(&(albumPtr[track]));

  strncpy_P(buffer, trackPtr, bufferSize);
  buffer[bufferSize - 1] = '\0';
}

void lcdPrintLine(byte row, const char* text) {
  lcd.setCursor(0, row);

  for (int i = 0; i < 16; i++) {
    if (text[i] == '\0') {
      for (; i < 16; i++) lcd.print(' ');
      break;
    }
    lcd.print(text[i]);
  }
}

void showHome() {
  lcd.clear();
  lcdPrintLine(0, "Select Album");
  lcdPrintLine(1, "Track then #");

  Serial.println("Select album, type track, press #");
}
