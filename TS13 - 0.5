void setup() {
  Serial.begin(9600);
  Wire.begin();
  randomSeed(analogRead(A0));

  pinMode(playPauseBtn, INPUT_PULLUP);
  pinMode(prevBtn, INPUT_PULLUP);
  pinMode(nextBtn, INPUT_PULLUP);
  pinMode(volDownBtn, INPUT_PULLUP);
  pinMode(volUpBtn, INPUT_PULLUP);

  lcd.init();
  lcd.backlight();
  lcd.createChar(0, heartChar);
  lcd.createChar(1, musicChar);
  lcd.createChar(2, discChar);
  lcd.createChar(3, shuffleChar);
  lcd.createChar(4, repeatChar);
  lcd.createChar(5, pauseChar);
  lcd.createChar(6, faceChar);
  lcd.createChar(7, starChar);
  lcd.clear();

  lcd.setCursor(0, 0);
  lcd.print("It's Me, ");
  lcd.write(byte(6));
  for (int i = 9; i < 16; i++) lcd.print(' ');
  lcdPrintLine(1, "Hi. . .");

  initFavorites();
  delay(1200);

  if (!mcp.begin_I2C(MCP_ADDR)) {
    Serial.println(F("MCP NOT FOUND"));
    lcdPrintLine(0, "MCP NOT FOUND");
    while (1);
  }

  setupKeypad(albumRows, albumCols);
  setupKeypad(trackRows, trackCols);

  mp3Serial.begin(9600);

  if (!mp3.begin(mp3Serial)) {
    Serial.println(F("DFPlayer ERROR"));
    lcdPrintLine(0, "DFPlayer ERROR");
    while (1);
  }

  mp3.volume(volumeLevel);

  showHome();
}

void loop() {
  checkMediaButtons();
  checkBusyAutoNext();
  checkVolumeScreenRestore();
  updatePeriodicCounter();
  updateScrollText();

  int album = scanAlbumKeypad();

  if (album > 0) {
    selectedAlbum = album;
    clearTypedTrack();
    albumPlayMode = false;
    favoritesBrowseMode = false;
    browseMode = true;
    previewTrack = 0;

    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));

    stopScrollText();
    lcd.clear();
    showAlbumLine(nameBuffer);
    lcdPrintLine(1, "Enter track");
  }

  checkSpecialKeyButtons();

  char key = scanTrackKeypad();

  if (key != 0) {
    handleTrackKey(key);
  }
}

void setupKeypad(byte rows[4], byte cols[3]) {
  for (int r = 0; r < 4; r++) {
    mcp.pinMode(rows[r], OUTPUT);
    mcp.digitalWrite(rows[r], HIGH);
  }

  for (int c = 0; c < 3; c++) {
    mcp.pinMode(cols[c], INPUT_PULLUP);
  }
}

int scanAlbumKeypad() {
  if (millis() - lastPress < debounceDelay) return 0;

  for (int r = 0; r < 4; r++) {
    setRowsHigh(albumRows);
    mcp.digitalWrite(albumRows[r], LOW);

    for (int c = 0; c < 3; c++) {
      if (mcp.digitalRead(albumCols[c]) == LOW) {
        lastPress = millis();
        return albumMap[r][c];
      }
    }
  }

  return 0;
}

char scanTrackKeypad() {
  if (millis() - lastPress < debounceDelay) return 0;

  for (int r = 0; r < 4; r++) {
    setRowsHigh(trackRows);
    mcp.digitalWrite(trackRows[r], LOW);

    for (int c = 0; c < 3; c++) {
      if (mcp.digitalRead(trackCols[c]) == LOW) {
        char key = trackMap[r][c];

        if (key == '*' || key == '#') {
          setRowsHigh(trackRows);
          return 0;
        }

        lastPress = millis();
        return key;
      }
    }
  }

  return 0;
}

void setRowsHigh(byte rows[4]) {
  for (int r = 0; r < 4; r++) {
    mcp.digitalWrite(rows[r], HIGH);
  }
}

void clearTypedTrack() {
  typedTrack[0] = '\0';
  typedTrackLen = 0;
}

void handleTrackKey(char key) {
  if (key >= '0' && key <= '9') {
    browseMode = false;
    previewTrack = 0;

    if (typedTrackLen < 3) {
      typedTrack[typedTrackLen] = key;
      typedTrackLen++;
      typedTrack[typedTrackLen] = '\0';
    }

    stopScrollText();
    char line[17];
    snprintf(line, sizeof(line), "Track: %s", typedTrack);
    lcdPrintLine(1, line);
  }
}

bool isTrackKeyDown(char target) {
  for (int r = 0; r < 4; r++) {
    setRowsHigh(trackRows);
    mcp.digitalWrite(trackRows[r], LOW);

    for (int c = 0; c < 3; c++) {
      if (trackMap[r][c] == target) {
        bool pressed = (mcp.digitalRead(trackCols[c]) == LOW);
        setRowsHigh(trackRows);
        return pressed;
      }
    }
  }

  return false;
}

void checkSpecialKeyButtons() {
  unsigned long now = millis();

  bool enterDown = isTrackKeyDown('#');
  bool starDown = isTrackKeyDown('*');

  if (enterDown && starDown && !enterStarComboDone) {
    goHomeScreen();
    enterStarComboDone = true;
    enterHoldDone = true;
    starHoldDone = true;
  }

  if (enterDown && !enterWasDown) {
    enterWasDown = true;
    enterHoldDone = false;
    enterPressTime = now;
  }

  if (enterDown && !enterHoldDone && !starDown && now - enterPressTime >= holdDelay) {
    enterHoldDone = true;
  }

  if (!enterDown && enterWasDown) {
    if (!enterHoldDone && !enterStarComboDone) {
      handleEnterShortPress();
    }

    enterWasDown = false;
    enterHoldDone = false;
  }

  if (starDown && !starWasDown) {
    starWasDown = true;
    starHoldDone = false;
    starPressTime = now;
  }

  if (starDown && !starHoldDone && !enterDown && now - starPressTime >= holdDelay) {
    toggleCurrentFavorite();
    starHoldDone = true;
  }

  if (!starDown && starWasDown) {
    if (!starHoldDone && !enterStarComboDone) {
      handleClearShortPress();
    }

    starWasDown = false;
    starHoldDone = false;
  }

  if (!enterDown && !starDown) {
    enterStarComboDone = false;
  }
}

void handleEnterShortPress() {
  if (favoritesBrowseMode && favoriteCount > 0) {
    playFavoriteAt(previewFavoriteIndex);
    favoritesBrowseMode = false;
    favoritesPlayMode = true;
    return;
  }

  if (typedTrackLen == 0) {
    if (browseMode && previewTrack > 0) {
      playPreviewTrack();
      return;
    }

    if (browseMode && selectedAlbum >= 1 && selectedAlbum <= 12) {
      playWholeAlbum();
      return;
    }

    if (currentAlbum >= 1 && currentTrack >= 1) {
      return;
    }

    playWholeAlbum();
  } else {
    playSong();
  }
}

void goHomeScreen() {
  selectedAlbum = 0;
  previewTrack = 0;
  browseMode = false;
  favoritesBrowseMode = false;
  favoritesPlayMode = false;
  albumPlayMode = false;
  repeatSong = false;
  shuffleAlbum = false;
  clearTypedTrack();
  showHome();
}

void handleClearShortPress() {
  if (typedTrackLen == 0 && !browseMode && !favoritesBrowseMode && selectedAlbum >= 1 && selectedAlbum <= 12) {
    selectedAlbum = 0;
    previewTrack = 0;
    browseMode = false;
    favoritesBrowseMode = false;
    clearTypedTrack();
    showHome();
    return;
  }

  clearTypedTrack();
  browseMode = false;
  favoritesBrowseMode = false;
  previewTrack = 0;

  stopScrollText();
  lcdPrintLine(1, "Cleared");
  delay(500);

  if (selectedAlbum >= 1 && selectedAlbum <= 12) {
    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));
    showAlbumLine(nameBuffer);
    lcdPrintLine(1, "Enter track");
  } else {
    showHome();
  }
}

void playSong() {
  if (selectedAlbum == 0) {
    int specialTrack = atoi(typedTrack);

    if (specialTrack == 13) {
      clearTypedTrack();
      playFavorites();
      return;
    }

    stopScrollText();
    lcdPrintLine(0, "Pick album");
    lcdPrintLine(1, "13#=Taylist");
    delay(1000);
    showHome();
    return;
  }

  if (typedTrackLen == 0) {
    stopScrollText();
    lcdPrintLine(1, "Type track");
    delay(1000);
    return;
  }

  int track = atoi(typedTrack);

  if (track < 1 || track > trackCounts[selectedAlbum]) {

    stopScrollText();
    lcdPrintLine(0, "Bad track");
    char msg[17];
    snprintf(msg, sizeof(msg), "1-%d only", trackCounts[selectedAlbum]);
    lcdPrintLine(1, msg);

    clearTypedTrack();
    delay(1500);

    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));
    stopScrollText();
    showAlbumLine(nameBuffer);
    lcdPrintLine(1, "Enter track");
    return;
  }

  char albumBuffer[24];
  char trackBuffer[64];

  getAlbumName(selectedAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(selectedAlbum, track, trackBuffer, sizeof(trackBuffer));

  showPlayingTrackOnLCD(albumBuffer, trackBuffer);

  currentAlbum = selectedAlbum;
  currentTrack = track;
  isPaused = false;
  albumPlayMode = false;
  favoritesPlayMode = false;
  favoritesBrowseMode = false;
  browseMode = false;
  previewTrack = 0;
  busyWasLow = false;
  trackStartTime = millis();

  mp3.playFolder(selectedAlbum, track);

  clearTypedTrack();
}

void playWholeAlbum() {
  if (selectedAlbum == 0) {
    stopScrollText();
    lcdPrintLine(0, "Pick album");
    lcdPrintLine(1, "");
    delay(1000);
    showHome();
    return;
  }

  currentAlbum = selectedAlbum;
  currentTrack = 1;
  albumPlayMode = true;
  favoritesPlayMode = false;
  favoritesBrowseMode = false;
  browseMode = false;
  previewTrack = 0;
  isPaused = false;
  busyWasLow = false;
  trackStartTime = millis();

  getAlbumName(currentAlbum, nameBuffer, sizeof(nameBuffer));

  playCurrentTrackFromButtons();
  albumPlayMode = true;  // playCurrentTrackFromButtons preserves this, but keep it explicit
}

void checkBusyAutoNext() {
  if (isPaused || currentAlbum < 1 || currentTrack < 1) return;
  if (!albumPlayMode && !repeatSong && !shuffleAlbum && !favoritesPlayMode) return;

  bool busyState = digitalRead(busyPin);

  if (busyState == LOW) {
    busyWasLow = true;
  }

  if (busyWasLow && busyState == HIGH && millis() - trackStartTime > 2000) {
    busyWasLow = false;

    if (repeatSong) {
      playCurrentTrackFromButtons();
      return;
    }

    if (favoritesPlayMode) {
      playNextFavorite();
      return;
    }

    if (shuffleAlbum) {
      playRandomTrackInCurrentAlbum();
      return;
    }

    if (albumPlayMode) {
      currentTrack++;

      if (currentTrack > trackCounts[currentAlbum]) {
        albumPlayMode = false;
        stopScrollText();
        lcdPrintLine(0, "Album done");
        lcdPrintLine(1, "");
        return;
      }

      playCurrentTrackFromButtons();
      albumPlayMode = true;
    }
  }
}

void checkMediaButtons() {
  unsigned long now = millis();

  bool playDown = (digitalRead(playPauseBtn) == LOW);
  bool prevDown = (digitalRead(prevBtn) == LOW);
  bool nextDown = (digitalRead(nextBtn) == LOW);
  bool volDownHeld = (digitalRead(volDownBtn) == LOW);
  bool volUpHeld = (digitalRead(volUpBtn) == LOW);

  if (volUpHeld && now - lastVolUpRepeat >= volumeRepeatDelay) {
    handleVolumeUp();
    lastVolUpRepeat = now;
  }

  if (volDownHeld && now - lastVolDownRepeat >= volumeRepeatDelay) {
    handleVolumeDown();
    lastVolDownRepeat = now;
  }

  if (playDown && prevDown && !playPrevComboDone) {
    toggleRepeatSong();
    playPrevComboDone = true;
    playHoldDone = true;
    prevHoldDone = true;
  }

  if (playDown && nextDown && !playNextComboDone) {
    toggleShuffleAlbum();
    playNextComboDone = true;
    playHoldDone = true;
  }

  if (playDown && !playWasDown) {
    playWasDown = true;
    playPressTime = now;
    playHoldDone = false;
  }

  if (playDown && !playHoldDone && !prevDown && !nextDown && now - playPressTime >= holdDelay) {
    playRandomSong();
    playHoldDone = true;
  }

  if (!playDown && playWasDown) {
    if (!playHoldDone && !playPrevComboDone && !playNextComboDone) {
      handlePlayPause();
    }

    playWasDown = false;
    playHoldDone = false;
  }

  if (prevDown && !prevWasDown) {
    prevWasDown = true;
    prevPressTime = now;
    prevHoldDone = false;
  }

  if (prevDown && !prevHoldDone && !playDown && now - prevPressTime >= holdDelay) {
    restartCurrentSong();
    prevHoldDone = true;
  }

  if (!prevDown && prevWasDown) {
    if (!prevHoldDone && !playPrevComboDone) {
      handlePrevious();
    }

    prevWasDown = false;
    prevHoldDone = false;
  }

  if (nextDown && !nextWasDown) {
    nextWasDown = true;
    nextPressTime = now;
  }

  if (!nextDown && nextWasDown) {
    if (!playNextComboDone) {
      handleNext();
    }

    nextWasDown = false;
  }

  if (!playDown && !prevDown) {
    playPrevComboDone = false;
  }

  if (!playDown && !nextDown) {
    playNextComboDone = false;
  }
}

void handlePlayPause() {
  if (currentAlbum == 0 || currentTrack == 0) {
    stopScrollText();
    lcdPrintLine(0, "Hold Play");
    lcdPrintLine(1, "for random");
    return;
  }

  if (isPaused) {
    mp3.start();
    isPaused = false;
    refreshMainScreen();
  } else {
    mp3.pause();
    isPaused = true;
    stopScrollText();
    lcd.setCursor(0, 0);
    lcd.write(byte(5));
    lcd.print(" Paused       ");
  }
}

void handleNext() {
  if (favoritesBrowseMode && favoriteCount > 0) {
    previewFavoriteIndex++;
    if (previewFavoriteIndex >= favoriteCount) previewFavoriteIndex = 0;
    showFavoritePreview();
    return;
  }

  if (browseMode && selectedAlbum >= 1 && selectedAlbum <= 12) {
    previewTrack++;
    if (previewTrack > trackCounts[selectedAlbum]) previewTrack = 1;
    showPreviewTrack();
    return;
  }

  if (favoritesPlayMode && favoriteCount > 0) {
    playNextFavorite();
    return;
  }

  if (currentAlbum >= 1 && currentAlbum <= 12 && currentTrack >= 1) {
    browseMode = false;
    previewTrack = 0;
    favoritesBrowseMode = false;

    if (shuffleAlbum) {
      playRandomTrackInCurrentAlbum();
      return;
    }

    currentTrack++;
    if (currentTrack > trackCounts[currentAlbum]) currentTrack = 1;
    playCurrentTrackFromButtons();
  } else {
    stopScrollText();
    lcdPrintLine(0, "Pick album");
    lcdPrintLine(1, "Hold Play=Rand");
  }
}

void handlePrevious() {
  if (favoritesBrowseMode && favoriteCount > 0) {
    if (previewFavoriteIndex == 0) {
      previewFavoriteIndex = favoriteCount - 1;
    } else {
      previewFavoriteIndex--;
    }
    showFavoritePreview();
    return;
  }

  if (browseMode && selectedAlbum >= 1 && selectedAlbum <= 12) {
    previewTrack--;
    if (previewTrack < 1) previewTrack = trackCounts[selectedAlbum];
    showPreviewTrack();
    return;
  }

  if (favoritesPlayMode && favoriteCount > 0) {
    if (currentFavoriteIndex == 0) currentFavoriteIndex = favoriteCount - 1;
    else currentFavoriteIndex--;
    playFavoriteAt(currentFavoriteIndex);
    return;
  }

  if (currentAlbum >= 1 && currentAlbum <= 12 && currentTrack >= 1) {
    browseMode = false;
    previewTrack = 0;
    favoritesBrowseMode = false;

    currentTrack--;
    if (currentTrack < 1) currentTrack = trackCounts[currentAlbum];
    playCurrentTrackFromButtons();
  } else {
    stopScrollText();
    lcdPrintLine(0, "Pick album");
    lcdPrintLine(1, "Hold Play=Rand");
  }
}

void playRandomSong() {
  currentAlbum = random(1, 13);
  currentTrack = random(1, trackCounts[currentAlbum] + 1);

  selectedAlbum = currentAlbum;
  clearTypedTrack();
  browseMode = false;
  favoritesBrowseMode = false;
  previewTrack = 0;
  albumPlayMode = false;
  favoritesPlayMode = false;
  repeatSong = false;

  playCurrentTrackFromButtons();
}

void showPreviewTrack() {
  if (selectedAlbum < 1 || selectedAlbum > 12 || previewTrack < 1) return;

  char albumBuffer[24];
  char trackBuffer[64];

  getAlbumName(selectedAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(selectedAlbum, previewTrack, trackBuffer, sizeof(trackBuffer));

  showTrackOnLCD(albumBuffer, trackBuffer);
}

void playPreviewTrack() {
  if (selectedAlbum < 1 || selectedAlbum > 12 || previewTrack < 1) return;

  currentAlbum = selectedAlbum;
  currentTrack = previewTrack;
  albumPlayMode = false;
  favoritesBrowseMode = false;
  browseMode = false;
  previewTrack = 0;

  playCurrentTrackFromButtons();
}

void playCurrentTrackFromButtons() {
  char albumBuffer[24];
  char trackBuffer[64];

  getAlbumName(currentAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(currentAlbum, currentTrack, trackBuffer, sizeof(trackBuffer));

  showPlayingTrackOnLCD(albumBuffer, trackBuffer);

  selectedAlbum = currentAlbum;
  clearTypedTrack();
  browseMode = false;
  favoritesBrowseMode = false;
  previewTrack = 0;
  isPaused = false;
  busyWasLow = false;
  trackStartTime = millis();
  scheduleSongCounter();

  mp3.playFolder(currentAlbum, currentTrack);
}

void handleVolumeUp() {
  if (volumeLevel < 30) {
    volumeLevel++;
    mp3.volume(volumeLevel);
  }

  showVolumeBar();
}

void handleVolumeDown() {
  if (volumeLevel > 0) {
    volumeLevel--;
    mp3.volume(volumeLevel);
  }

  showVolumeBar();
}

void showVolumeBar() {
  stopScrollText();
  volumeScreenActive = true;
  lastVolumeAction = millis();

  char top[17];

  if (volumeLevel >= 30) {
    snprintf(top, sizeof(top), "Volume: MAX");
  } else if (volumeLevel <= 0) {
    snprintf(top, sizeof(top), "Volume: MIN");
  } else {
    snprintf(top, sizeof(top), "Volume: %d", volumeLevel);
  }

  lcdPrintLine(0, top);

  int bars = map(volumeLevel, 0, 30, 0, 14);

  lcd.setCursor(0, 1);
  lcd.print("[");
  for (int i = 0; i < 14; i++) {
    if (i < bars) {
      lcd.print("|");
    } else {
      lcd.print(" ");
    }
  }
  lcd.print("]");
}

void checkVolumeScreenRestore() {
  if (!volumeScreenActive) return;

  bool volDownHeld = (digitalRead(volDownBtn) == LOW);
  bool volUpHeld = (digitalRead(volUpBtn) == LOW);

  if (!volDownHeld && !volUpHeld && millis() - lastVolumeAction >= volumeRestoreDelay) {
    volumeScreenActive = false;
    refreshMainScreen();
  }
}

void refreshMainScreen() {
  if (currentAlbum >= 1 && currentAlbum <= 12 && currentTrack >= 1) {
    char albumBuffer[24];
    char trackBuffer[64];

    getAlbumName(currentAlbum, albumBuffer, sizeof(albumBuffer));
    getTrackName(currentAlbum, currentTrack, trackBuffer, sizeof(trackBuffer));

    showTrackOnLCD(albumBuffer, trackBuffer);
    return;
  }

  if (favoritesBrowseMode && favoriteCount > 0) {
    showFavoritePreview();
    return;
  }

  if (browseMode && selectedAlbum >= 1 && selectedAlbum <= 12 && previewTrack >= 1) {
    showPreviewTrack();
    return;
  }

  if (selectedAlbum >= 1 && selectedAlbum <= 12) {
    getAlbumName(selectedAlbum, nameBuffer, sizeof(nameBuffer));
    stopScrollText();
    lcd.clear();
    showAlbumLine(nameBuffer);
    lcdPrintLine(1, "Enter track");
    return;
  }

  showHome();
}

void toggleRepeatSong() {
  if (currentAlbum == 0 || currentTrack == 0) {
    stopScrollText();
    lcdPrintLine(0, "No song yet");
    lcdPrintLine(1, "No repeat");
    return;
  }

  repeatSong = !repeatSong;

  char trackBuffer[64];
  getTrackName(currentAlbum, currentTrack, trackBuffer, sizeof(trackBuffer));

  stopScrollText();
  lcdPrintLine(0, repeatSong ? "Repeat ON" : "Repeat OFF");
  lcdPrintLine(1, trackBuffer);
}

void toggleShuffleAlbum() {
  int albumForShuffle = currentAlbum;

  if (albumForShuffle == 0 && selectedAlbum >= 1 && selectedAlbum <= 12) {
    albumForShuffle = selectedAlbum;
  }

  if (albumForShuffle < 1 || albumForShuffle > 12) {
    stopScrollText();
    lcdPrintLine(0, "Pick album");
    lcdPrintLine(1, "No shuffle");
    return;
  }

  currentAlbum = albumForShuffle;
  selectedAlbum = albumForShuffle;
  shuffleAlbum = !shuffleAlbum;
  browseMode = false;
  previewTrack = 0;
  favoritesBrowseMode = false;

  char albumBuffer[24];
  getAlbumName(currentAlbum, albumBuffer, sizeof(albumBuffer));

  stopScrollText();
  lcdPrintLine(0, shuffleAlbum ? "Shuffle ON" : "Shuffle OFF");
  lcdPrintLine(1, albumBuffer);
}

void restartCurrentSong() {
  if (currentAlbum < 1 || currentAlbum > 12 || currentTrack < 1) {
    stopScrollText();
    lcdPrintLine(0, "No song yet");
    lcdPrintLine(1, "");
    return;
  }

  playCurrentTrackFromButtons();
}

void playRandomTrackInCurrentAlbum() {
  if (currentAlbum < 1 || currentAlbum > 12) return;

  browseMode = false;
  previewTrack = 0;
  favoritesBrowseMode = false;

  if (trackCounts[currentAlbum] <= 1) {
    currentTrack = 1;
  } else {
    int nextTrack;
    do {
      nextTrack = random(1, trackCounts[currentAlbum] + 1);
    } while (nextTrack == currentTrack);

    currentTrack = nextTrack;
  }

  playCurrentTrackFromButtons();
}

void initFavorites() {
  if (EEPROM.read(EEPROM_MAGIC_ADDR) != EEPROM_MAGIC) {
    EEPROM.update(EEPROM_MAGIC_ADDR, EEPROM_MAGIC);
    EEPROM.update(EEPROM_COUNT_ADDR, 0);
  }

  favoriteCount = EEPROM.read(EEPROM_COUNT_ADDR);

  if (favoriteCount > MAX_FAVORITES) {
    favoriteCount = 0;
    EEPROM.update(EEPROM_COUNT_ADDR, 0);
  }
}

int favoriteAddress(byte index) {
  return EEPROM_FAV_START + (index * 2);
}

void readFavorite(byte index, byte &album, byte &track) {
  int addr = favoriteAddress(index);
  album = EEPROM.read(addr);
  track = EEPROM.read(addr + 1);
}

void writeFavorite(byte index, byte album, byte track) {
  int addr = favoriteAddress(index);
  EEPROM.update(addr, album);
  EEPROM.update(addr + 1, track);
}

int findFavorite(byte album, byte track) {
  for (byte i = 0; i < favoriteCount; i++) {
    byte favAlbum, favTrack;
    readFavorite(i, favAlbum, favTrack);

    if (favAlbum == album && favTrack == track) {
      return i;
    }
  }

  return -1;
}

void toggleCurrentFavorite() {
  byte favAlbum = 0;
  byte favTrack = 0;

  if (favoritesBrowseMode && favoriteCount > 0 && previewFavoriteIndex < favoriteCount) {
    readFavorite(previewFavoriteIndex, favAlbum, favTrack);
  } else if (browseMode && selectedAlbum >= 1 && selectedAlbum <= 12 && previewTrack >= 1) {
    favAlbum = selectedAlbum;
    favTrack = previewTrack;
  } else if (currentAlbum >= 1 && currentAlbum <= 12 && currentTrack >= 1) {
    favAlbum = currentAlbum;
    favTrack = currentTrack;
  }

  if (favAlbum < 1 || favAlbum > 12 || favTrack < 1 || favTrack > trackCounts[favAlbum]) {
    stopScrollText();
    lcdPrintLine(0, "Hold * on song");
    lcdPrintLine(1, "to Heart");
    return;
  }

  int existingIndex = findFavorite(favAlbum, favTrack);

  char trackBuffer[64];
  getTrackName(favAlbum, favTrack, trackBuffer, sizeof(trackBuffer));

  if (existingIndex >= 0) {
    for (byte i = existingIndex; i < favoriteCount - 1; i++) {
      byte nextAlbum, nextTrack;
      readFavorite(i + 1, nextAlbum, nextTrack);
      writeFavorite(i, nextAlbum, nextTrack);
    }

    favoriteCount--;
    EEPROM.update(EEPROM_COUNT_ADDR, favoriteCount);

    if (favoritesBrowseMode) {
      if (favoriteCount == 0) {
        favoritesBrowseMode = false;
      } else if (previewFavoriteIndex >= favoriteCount) {
        previewFavoriteIndex = favoriteCount - 1;
      }
    }

    stopScrollText();
    lcdPrintLine(0, "un-Hearted :(");
    lcdPrintLine(1, trackBuffer);
    return;
  }

  if (favoriteCount >= MAX_FAVORITES) {
    stopScrollText();
    lcdPrintLine(0, "Taylist Full");
    lcdPrintLine(1, "");
    return;
  }

  writeFavorite(favoriteCount, favAlbum, favTrack);
  favoriteCount++;
  EEPROM.update(EEPROM_COUNT_ADDR, favoriteCount);

  stopScrollText();
  lcdPrintLine(0, "Hearted :)");
  lcdPrintLine(1, trackBuffer);
}

void playFavorites() {
  if (favoriteCount == 0) {
    stopScrollText();
    lcdPrintLine(0, "No Taylist");
    lcdPrintLine(1, "Hold *=Heart");
    return;
  }

  favoritesPlayMode = false;
  favoritesBrowseMode = true;
  albumPlayMode = false;
  shuffleAlbum = false;
  browseMode = false;
  previewTrack = 0;
  previewFavoriteIndex = 0;

  stopScrollText();
  lcd.setCursor(0, 0);
  lcd.write(byte(7));
  lcd.print(" My Taylist    ");
  char msg[17];
  snprintf(msg, sizeof(msg), "%d Songs", favoriteCount);
  lcdPrintLine(1, msg);
  delay(900);

  showFavoritePreview();
}

void showFavoritePreview() {
  if (favoriteCount == 0 || previewFavoriteIndex >= favoriteCount) return;

  byte favAlbum, favTrack;
  readFavorite(previewFavoriteIndex, favAlbum, favTrack);

  if (favAlbum < 1 || favAlbum > 12 || favTrack < 1 || favTrack > trackCounts[favAlbum]) {
    return;
  }

  char albumBuffer[24];
  char trackBuffer[64];
  char line2[64];

  getAlbumName(favAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(favAlbum, favTrack, trackBuffer, sizeof(trackBuffer));

  snprintf(line2, sizeof(line2), "[%s] %s", albumBuffer, trackBuffer);

  showTaylistOnLCD(line2);
}

void playFavoriteAt(byte index) {
  if (index >= favoriteCount) return;

  byte favAlbum, favTrack;
  readFavorite(index, favAlbum, favTrack);

  if (favAlbum < 1 || favAlbum > 12 || favTrack < 1 || favTrack > trackCounts[favAlbum]) {
    playNextFavorite();
    return;
  }

  currentFavoriteIndex = index;
  currentAlbum = favAlbum;
  currentTrack = favTrack;
  selectedAlbum = currentAlbum;
  clearTypedTrack();

  char albumBuffer[24];
  char trackBuffer[64];
  char line2[64];

  getAlbumName(currentAlbum, albumBuffer, sizeof(albumBuffer));
  getTrackName(currentAlbum, currentTrack, trackBuffer, sizeof(trackBuffer));
  snprintf(line2, sizeof(line2), "[%s] %s", albumBuffer, trackBuffer);

  showTaylistOnLCD(line2);

  favoritesBrowseMode = false;
  favoritesPlayMode = true;
  isPaused = false;
  busyWasLow = false;
  trackStartTime = millis();
  scheduleSongCounter();

  mp3.playFolder(currentAlbum, currentTrack);
}

void playNextFavorite() {
  if (!favoritesPlayMode || favoriteCount == 0) return;

  currentFavoriteIndex++;

  if (currentFavoriteIndex >= favoriteCount) {
    currentFavoriteIndex = 0;
  }

  playFavoriteAt(currentFavoriteIndex);
}

void getAlbumName(int album, char* buffer, size_t bufferSize) {
  if (album < 1 || album > 12) {
    strncpy(buffer, "Unknown Album", bufferSize);
    buffer[bufferSize - 1] = '\0';
    return;
  }

  PGM_P ptr = (PGM_P)pgm_read_word(&(albumNames[album]));
  strncpy_P(buffer, ptr, bufferSize);
  buffer[bufferSize - 1] = '\0';
}

void getTrackName(int album, int track, char* buffer, size_t bufferSize) {
  if (album < 1 || album > 12 || track < 1 || track > trackCounts[album]) {
    strncpy(buffer, "Unknown Track", bufferSize);
    buffer[bufferSize - 1] = '\0';
    return;
  }

  const char* const* albumPtr = (const char* const*)pgm_read_word(&(allTracks[album]));
  PGM_P trackPtr = (PGM_P)pgm_read_word(&(albumPtr[track]));

  strncpy_P(buffer, trackPtr, bufferSize);
  buffer[bufferSize - 1] = '\0';
}

void lcdPrintLine(byte row, const char* text) {
  lcd.setCursor(0, row);

  for (int i = 0; i < 16; i++) {
    if (text[i] == '\0') {
      for (; i < 16; i++) lcd.print(' ');
      break;
    }
    lcd.print(text[i]);
  }
}

void stopScrollText() {
  counterFlashActive = false;
  scrollActive = false;
  scrollAtEnd = false;
  scrollPos = 0;
}


void showAlbumLine(const char* albumText) {
  stopScrollText();

  lcd.setCursor(0, 0);
  lcd.write(byte(2));
  lcd.print(' ');

  int len = strlen(albumText);

  if (len <= 14) {
    for (int i = 0; i < 14; i++) {
      if (albumText[i] == '\0') {
        for (; i < 14; i++) lcd.print(' ');
        break;
      }
      lcd.print(albumText[i]);
    }
    return;
  }

  strncpy(scrollBuffer, albumText, sizeof(scrollBuffer));
  scrollBuffer[sizeof(scrollBuffer) - 1] = '\0';

  scrollRow = 0;
  scrollActive = true;
  scrollAtEnd = false;
  scrollPos = 0;
  lastScrollMove = millis();

  lcd.setCursor(2, 0);
  for (int i = 0; i < 14; i++) {
    lcd.print(scrollBuffer[i]);
  }
}


