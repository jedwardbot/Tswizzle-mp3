void scheduleSongCounter() {
  counterFlashActive = false;
  if (favoritesPlayMode) {
    nextCounterTime = millis() + counterInitialDelay;
  } else {
    nextCounterTime = 0;
  }
}

void showSongCounterBrief() {
  if (!favoritesPlayMode || favoriteCount == 0) return;
  if (counterFlashActive) return;

  char msg[17];
  snprintf(msg, sizeof(msg), "Tay %d/%d", currentFavoriteIndex + 1, favoriteCount);

  lcdPrintLine(0, msg);
  counterFlashActive = true;
  counterFlashStart = millis();
  nextCounterTime = millis() + counterRepeatDelay;
}

void updatePeriodicCounter() {
  if (volumeScreenActive) return;
  if (!favoritesPlayMode || favoriteCount == 0) return;
  if (currentAlbum < 1 || currentAlbum > 12 || currentTrack < 1) return;
  if (browseMode || favoritesBrowseMode) return;

  if (counterFlashActive) {
    if (millis() - counterFlashStart >= counterFlashDelay) {
      counterFlashActive = false;
      refreshMainScreen();
    }
    return;
  }

  if (nextCounterTime > 0 && millis() >= nextCounterTime) {
    showSongCounterBrief();
  }
}

void updateScrollText() {
  if (!scrollActive) return;

  int len = strlen(scrollBuffer);

  byte width = (scrollRow == 0 || (scrollRow == 1 && currentTrack > 0 && !favoritesBrowseMode)) ? 14 : 16;
  byte startCol = (scrollRow == 0 || (scrollRow == 1 && currentTrack > 0 && !favoritesBrowseMode)) ? 2 : 0;

  if (len <= width) {
    scrollActive = false;
    return;
  }

  unsigned long now = millis();

  if (scrollAtEnd) {
    if (now - lastScrollMove >= scrollEndPause) {
      scrollPos = 0;
      scrollAtEnd = false;
      lastScrollMove = now;

      lcd.setCursor(startCol, scrollRow);
      for (int i = 0; i < width; i++) {
        lcd.print(scrollBuffer[i]);
      }
    }
    return;
  }

  if (scrollPos == 0) {
    if (now - lastScrollMove < scrollStartPause) return;
  } else {
    if (now - lastScrollMove < scrollStepDelay) return;
  }

  scrollPos++;

  int maxPos = len - width;
  if (scrollPos >= maxPos) {
    scrollPos = maxPos;
    scrollAtEnd = true;
  }

  lcd.setCursor(startCol, scrollRow);
  for (int i = 0; i < width; i++) {
    lcd.print(scrollBuffer[scrollPos + i]);
  }

  lastScrollMove = now;
}


